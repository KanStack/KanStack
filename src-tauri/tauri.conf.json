{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Kanstack",
  "version": "0.4.0",
  "identifier": "com.kanstack.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kanstack",
        "width": 1440,
        "height": 920,
        "maximized": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": false
  }
}
