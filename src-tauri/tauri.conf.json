{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "KanStack",
  "version": "0.5.3",
  "identifier": "com.kanstack.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1440,
        "height": 920,
        "maximized": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": false,
    "resources": {
      "./Credits.html": "Credits.html"
    }
  }
}
